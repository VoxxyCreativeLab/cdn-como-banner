  "texts": {
    "en": {
      "banner": {
        "title": "We use cookies to fuel creativity ⚡",
        "description": "We use cookies to personalise content and ads, to provide social media features and to analyse our traffic. We also share information about your use of our site with our social media, advertising and analytics partners who may combine it with other information that you’ve provided to them or that they’ve collected from your use of their services."
      },
      "tabs": {
        "consent": "Consent",
        "details": "Details",
        "about": "About"
      },
      "buttons": {
        "allowAll": "Allow all",
        "denyAll": "Deny all",
        "customize": "Customize",
        "allowSelection": "Allow selection",
        "managePreferences": "Manage preferences",
        "doNotSell": "Do Not Sell or Share My Personal Information"
      },
      "about": {
        "title": "About Cookies",
        "description": "Cookies are small text files that can be used by websites to make a user experience more efficient. The law states that we can store cookies on your device if they are strictly necessary for the operation of this site. For all other types of cookies we need your permission.",
        "privacyLink": "For more information, see our {link}.",
        "privacyLinkText": "Privacy Policy",
        "controllerText": "This website is operated by {controller}. As the data controller, we are responsible for the processing of your personal data."
      },
      "categories": {
        "necessary": {
          "name": "Necessary",
          "description": "Necessary cookies help make a website usable by enabling basic functions like page navigation and access to secure areas of the website. The website cannot function properly without these cookies."
        },
        "preferences": {
          "name": "Preferences",
          "description": "Preference cookies enable a website to remember information that changes the way the website behaves or looks, like your preferred language or the region that you are in."
        },
        "analytics": {
          "name": "Statistics",
          "description": "Statistic cookies help website owners to understand how visitors interact with websites by collecting and reporting information anonymously."
        },
        "marketing": {
          "name": "Marketing",
          "description": "Marketing cookies are used to track visitors across websites. The intention is to display ads that are relevant and engaging for the individual user and thereby more valuable for publishers and third party advertisers."
        }
      },
      "closeButton": {
        "ariaLabel": "Dismiss"
      },
      "widget": {
        "ariaLabel": "Manage cookie preferences"
      },
      "aria": {
        "toggleLabel": "{name} cookies",
        "toggleLabelAlwaysOn": "{name} cookies (always active)"
      },
      "cookieTable": {
        "name": "Name",
        "purpose": "Purpose",
        "duration": "Duration",
        "provider": "Provider"
      }
    }
  },
